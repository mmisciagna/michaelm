<html>
  <head>
    <meta charset="utf-8">
    <meta content="width=device-width, initial-scale=1" name="viewport">
    <meta content="Michael Misciagna" name="author">
    <meta name="description" content="">
    <title>{{ title }} | Michael M.</title>
    <link href="/dist/img/favicon-48x48.png" rel="icon" sizes="48x48">
    <link href="/dist/img/favicon-72x72.png" rel="icon" sizes="72x72">
    <link href="/dist/img/favicon-96x96.png" rel="icon" sizes="96x96">
    <link href="/dist/img/favicon-144x144.png" rel="icon" sizes="144x144">
    <link href="https://fonts.googleapis.com/css?family=Source+Sans+Pro:200,300,400" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css?family=Source+Serif+Pro:400,600" rel="stylesheet">
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet">
    <link href="/dist/css/main.min.css" rel="stylesheet">
  </head>
  <body>
    {% import '/partials/macros.jinja' as macros %}
    {% include "/partials/header.jinja" %}
    {% include "/partials/mobile-nav.jinja" %}
    <main class="main">
      {% for section in content %}
        <section class="section">
          {% if section.headline %}
            {% include "/partials/headline.jinja" %}
          {% endif %}

          {% if section.title %}
            {% include "/partials/title.jinja" %}
          {% endif %}

          {% if section.figure %}
            {% include "/partials/figure.jinja" %}
          {% endif %}

          {% if section.paragraphs %}
            {% include "/partials/paragraphs.jinja" %}
          {% endif %}
        </section>
      {% endfor %}
    </main>
    {% include "/partials/footer.jinja" %}
    <script src="/dist/js/main.min.js"></script>
  </body>
</html>
